@model ProposalsViewModel
@{
    ViewData["Title"] = "Proposals Review";
    var f = Model.Filter;
    var isManager = User.IsInRole("Manager");
    var cur = ViewData.CurrencyCode();
}

<div class="d-flex justify-content-between align-items-center">
    <h1 class="h3">Proposals Review</h1>
    @if (Model.Run is not null)
    {
        <div class="text-muted">
            Run <strong>#@Model.Run.Id</strong> (@Model.Run.Status) — started @Model.Run.StartedUtc.ToString("u"),
            @Model.Run.SkuCount SKUs, @Model.Run.SkippedCount skipped, @Model.Run.ErrorCount errors
        </div>
    }
</div>

@if (Model.Run is null)
{
    <div class="alert alert-info mt-3">No pricing runs yet. Go to <a asp-controller="Schedule" asp-action="Index">Schedule</a> and hit <em>Run now</em>.</div>
    return;
}

@await Html.PartialAsync("_KpiCards", Model.Kpis)

<form method="get" class="row g-2 align-items-end my-3">
    <div class="col-auto">
        <label class="form-label mb-0">Run</label>
        <select name="RunId" class="form-select form-select-sm">
            @foreach (var run in Model.RecentRuns)
            {
                <option value="@run.Id" selected="@(run.Id == Model.Run.Id)">#@run.Id — @run.StartedUtc.ToString("MM-dd HH:mm") (@run.Status)</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label mb-0">SKU</label>
        <input type="search" name="Sku" value="@f.Sku" class="form-control form-control-sm" style="width:170px" placeholder="search SKU…" />
    </div>
    <div class="col-auto">
        <label class="form-label mb-0">Band</label>
        <select name="BandId" class="form-select form-select-sm">
            <option value="">All</option>
            @foreach (var band in Model.Bands)
            {
                <option value="@band.Id" selected="@(f.BandId == band.Id)">@band.Name</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label mb-0">Algorithm</label>
        <select name="Algorithm" class="form-select form-select-sm">
            <option value="">All</option>
            @foreach (var code in Model.AlgorithmCodes)
            {
                <option value="@code" selected="@(f.Algorithm == code)">@code</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label mb-0">Min |Δ%|</label>
        <input type="number" step="0.5" name="MinAbsChangePct" value="@f.MinAbsChangePct" class="form-control form-control-sm" style="width:90px" />
    </div>
    <div class="col-auto">
        <label class="form-label mb-0">Status</label>
        <select name="Status" class="form-select form-select-sm">
            @foreach (var s in new[] { "Pending", "Approved", "Rejected", "Pushed", "Skipped", "All" })
            {
                <option value="@s" selected="@(f.Status == s)">@s</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label mb-0">Sort</label>
        <select name="Sort" class="form-select form-select-sm">
            <option value="change_desc" selected="@(f.Sort == "change_desc")">|Δ%| desc</option>
            <option value="change_asc" selected="@(f.Sort == "change_asc")">Δ% asc</option>
            <option value="sku" selected="@(f.Sort == "sku")">SKU</option>
            <option value="price_desc" selected="@(f.Sort == "price_desc")">Price desc</option>
        </select>
    </div>
    <div class="col-auto form-check mb-1">
        @* Hidden fallback so UN-checking actually submits ChangedOnly=false. It must come AFTER
           the checkbox: when checked the browser submits true,false and the binder takes the first
           (true); when unchecked only false is sent. *@
        <input class="form-check-input" type="checkbox" name="ChangedOnly" value="true" checked="@f.ChangedOnly" id="changedOnly" />
        <input type="hidden" name="ChangedOnly" value="false" />
        <label class="form-check-label" for="changedOnly">Changed only</label>
    </div>
    <div class="col-auto"><button class="btn btn-sm btn-primary">Apply</button></div>
    <div class="col-auto"><button class="btn btn-sm btn-outline-success" formaction="@Url.Action("Export")" formmethod="get">Export CSV</button></div>
    <div class="col-auto text-muted"><small>@Model.TotalCount match · showing first @Model.Proposals.Count · @Model.ApprovedCount approved in run · export is the full filtered set</small></div>
</form>

<form method="post" id="reviewForm">
    @Html.AntiForgeryToken()
    <input type="hidden" name="runId" value="@Model.Run.Id" />
    <input type="hidden" name="BandId" value="@f.BandId" />
    <input type="hidden" name="Algorithm" value="@f.Algorithm" />
    <input type="hidden" name="Sku" value="@f.Sku" />
    <input type="hidden" name="MinAbsChangePct" value="@f.MinAbsChangePct" />
    <input type="hidden" name="Status" value="@f.Status" />
    <input type="hidden" name="ChangedOnly" value="@f.ChangedOnly.ToString().ToLower()" />
    <input type="hidden" name="Sort" value="@f.Sort" />
    <input type="hidden" name="confirmLarge" id="confirmLarge" value="false" />

    @if (isManager)
    {
        <div class="mb-2 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-success" formaction="@Url.Action("Approve")">Approve selected</button>
            <button type="submit" class="btn btn-sm btn-outline-success" formaction="@Url.Action("ApproveAll")"
                    onclick="return confirm('Approve ALL @Model.TotalCount proposals matching the current filter?');">Approve all (filtered)</button>
            <button type="submit" class="btn btn-sm btn-outline-danger" formaction="@Url.Action("Reject")">Reject selected</button>
            <button type="submit" class="btn btn-sm btn-warning ms-auto" formaction="@Url.Action("Push")"
                    onclick="return confirm('Push all @Model.ApprovedCount APPROVED proposals of run #@Model.Run.Id to the integration point? This is the explicit live-price step.');">
                ⬆ Push @Model.ApprovedCount approved
            </button>
        </div>
    }

    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                @if (isManager) { <th><input type="checkbox" id="checkAll" /></th> }
                <th>SKU</th><th>Band</th>
                <th class="text-end">Cost @cur</th>
                <th class="text-end">Old @cur</th><th class="text-end">Anchor @cur</th><th class="text-end">Current @cur</th><th class="text-end">Proposed @cur</th>
                <th class="text-end">Δ%</th>
                <th>Reasons</th><th>Guardrails</th><th>Status</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in Model.Proposals)
        {
            var bandName = Model.Bands.FirstOrDefault(b => b.Id == p.PriceBandId)?.Name ?? "–";
            var large = Math.Abs(p.ChangePct) > Model.ConfirmationThresholdPct;
            <tr class="@(large ? "table-warning" : "")">
                @if (isManager)
                {
                    <td>
                        @if (p.Status == ProposalStatus.Pending || p.Status == ProposalStatus.Approved)
                        {
                            <input type="checkbox" name="ids" value="@p.Id" class="rowCheck" data-large="@large.ToString().ToLower()" />
                        }
                    </td>
                }
                <td>
                    <a asp-controller="Sku" asp-action="Details" asp-route-id="@p.Sku">@p.Sku</a>
                    @if (ReasonCodeText.IsNewProduct(p.ReasonCodes, p.GuardrailFlags))
                    {
                        <span class="badge bg-info text-dark ms-1" title="New product (MarkAsNew window) — price held, no discount">NEW</span>
                    }
                </td>
                <td><small>@bandName</small></td>
                <td class="text-end">@(p.Pptcv.HasValue ? p.Pptcv.Value.ToString("0.00") : "–")</td>
                <td class="text-end text-muted">@p.OldPrice.ToString("0.00")</td>
                <td class="text-end">@p.AnchorPrice.ToString("0.00")</td>
                <td class="text-end">@p.CurrentPrice.ToString("0.00")</td>
                <td class="text-end fw-bold">@p.ProposedPriceValue.ToString("0.00")</td>
                <td class="text-end @(p.ChangePct > 0 ? "text-success" : p.ChangePct < 0 ? "text-danger" : "text-muted")">
                    @p.ChangePct.ToString("+0.##;-0.##;0")%
                    @if (large) { <span title="Exceeds ±@Model.ConfirmationThresholdPct% — requires confirmation">⚠</span> }
                </td>
                <td>
                    @foreach (var (code, text) in ReasonCodeText.DescribeList(p.ReasonCodes, ReasonCodeText.NewProductCode))
                    {
                        <span class="badge bg-light text-dark border" title="@code">@text</span>
                    }
                </td>
                <td>
                    @foreach (var (code, text) in ReasonCodeText.DescribeList(p.GuardrailFlags))
                    {
                        <span class="badge bg-secondary" title="@code">@text</span>
                    }
                </td>
                <td><span class="badge @(p.Status switch {
                        ProposalStatus.Approved => "bg-success",
                        ProposalStatus.Rejected => "bg-danger",
                        ProposalStatus.Pushed => "bg-primary",
                        ProposalStatus.Skipped => "bg-warning text-dark",
                        _ => "bg-secondary" })">@p.Status</span></td>
            </tr>
        }
        @if (!Model.Proposals.Any())
        {
            <tr><td colspan="11" class="text-muted">Nothing matches the current filter.</td></tr>
        }
        </tbody>
    </table>
</form>

@section Scripts {
<script>
    document.getElementById('checkAll')?.addEventListener('change', e =>
        document.querySelectorAll('.rowCheck').forEach(c => c.checked = e.target.checked));

    // Large-change confirmation (server enforces it too): if any selected row exceeds the
    // threshold, ask once and set the confirmLarge flag the server requires.
    document.getElementById('reviewForm')?.addEventListener('submit', e => {
        const action = e.submitter?.getAttribute('formaction') || '';
        if (!action.includes('Approve')) return;
        const selectedLarge = [...document.querySelectorAll('.rowCheck:checked')]
            .filter(c => c.dataset.large === 'true').length;
        const approvingAll = action.includes('ApproveAll');
        if (selectedLarge > 0 || approvingAll) {
            if (!confirm('Selection may include changes beyond ±@(Model.ConfirmationThresholdPct)%. Confirm large price changes?')) {
                e.preventDefault();
                return;
            }
            document.getElementById('confirmLarge').value = 'true';
        }
    });
</script>
}
