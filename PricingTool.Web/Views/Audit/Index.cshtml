@model AuditViewModel
@{
    ViewData["Title"] = "Audit Log";
}

<h1 class="h3">Audit Log</h1>
<p class="text-muted">Every configuration change and every price push — who, what, when, old → new.</p>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label mb-0">Search</label>
        <input name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="user, action, SKU, value…" />
    </div>
    <div class="col-auto">
        <label class="form-label mb-0">Category</label>
        <select name="category" class="form-select form-select-sm">
            <option value="">All</option>
            @foreach (var c in new[] { "Config", "Push", "Run", "Review" })
            {
                <option value="@c" selected="@(Model.Category == c)">@c</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label mb-0">From</label>
        <input name="from" type="date" value="@Model.From?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <label class="form-label mb-0">To</label>
        <input name="to" type="date" value="@Model.To?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
    </div>
    <div class="col-auto"><button class="btn btn-sm btn-primary">Filter</button></div>
</form>

<table class="table table-sm table-hover">
    <thead class="table-light">
        <tr><th>When (UTC)</th><th>User</th><th>Category</th><th>Action</th><th>Entity</th><th>Old</th><th>New</th></tr>
    </thead>
    <tbody>
    @foreach (var entry in Model.Entries)
    {
        <tr>
            <td class="text-nowrap">@entry.TimestampUtc.ToString("u")</td>
            <td>@entry.UserName</td>
            <td><span class="badge @(entry.Category == "Push" ? "bg-primary" : entry.Category == "Config" ? "bg-warning text-dark" : "bg-secondary")">@entry.Category</span></td>
            <td>@entry.Action</td>
            <td><small>@entry.EntityType @entry.EntityId</small></td>
            <td style="max-width:280px"><small class="text-muted text-break">@entry.OldValue</small></td>
            <td style="max-width:280px"><small class="text-break">@entry.NewValue</small></td>
        </tr>
    }
    @if (!Model.Entries.Any()) { <tr><td colspan="7" class="text-muted">No entries match.</td></tr> }
    </tbody>
</table>
<p class="text-muted"><small>Showing newest @Model.Entries.Count entries (max 200).</small></p>
