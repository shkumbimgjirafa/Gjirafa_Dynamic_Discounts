@model List<PriceBand>
@{
    ViewData["Title"] = "Price Bands";
    var conventionNames = new Dictionary<int, string> { [0] = "None", [1] = ".99 endings", [2] = ".95 endings", [3] = "Whole €", [4] = "995-style (€5 steps)" };
}

<h1 class="h3">Price Bands</h1>
<div class="alert alert-warning">
    <strong>Placeholder boundaries.</strong> Bands 2–7 must be confirmed with the team before go-live (open decision #3).
</div>

<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Band</th><th class="text-end">Range (OldPrice, €)</th>
            <th class="text-end">Margin floor</th><th class="text-end">Discount ceiling</th>
            <th>Rounding</th><th class="text-end">Algorithms on</th><th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var band in Model)
    {
        <tr>
            <td><strong>@band.Name</strong></td>
            <td class="text-end">@band.MinPrice.ToString("N0") – @band.MaxPrice.ToString("N0")</td>
            <td class="text-end">@band.MarginFloorPct.ToString("0.#")%</td>
            <td class="text-end">@band.DiscountCeilingPct.ToString("0.#")%</td>
            <td>@(conventionNames.GetValueOrDefault(band.RoundingConvention, "?")) @(band.RoundingEnabled ? "" : "(off)")</td>
            <td class="text-end">@band.AlgorithmSettings.Count(s => s.Enabled) / @band.AlgorithmSettings.Count</td>
            <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@band.Id">
                @(User.IsInRole("Manager") ? "Edit" : "View")</a></td>
        </tr>
    }
    </tbody>
</table>
